# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots

# Bundle artifact
*.jsbundle

# CocoaPods
/ios/Pods/

# Fonts (downloaded via `yarn setup:artsy`)
assets/fonts/*

# Ignore env files
**/.env*
!.env.example

# react-native-keys — real keys files hold secrets; only the example is tracked
keys*.json
!keys.example.json

# Relay — ignore generated artifacts but keep the directory so the
# relay-compiler `artifactDirectory` exists on a fresh checkout.
src/__generated__/*
!src/__generated__/.gitkeep

# Metro health check
.metro-health-check*

# for tsconfig `incremental`
tsconfig.tsbuildinfo

# testing
/coverage

# VitePress docs site (build output + cache)
docs/.vitepress/dist
docs/.vitepress/cache

# Expo + prebuild (native projects are generated, not committed)
.expo
dist/
web-build/
/android
/ios

# yarn 4
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
