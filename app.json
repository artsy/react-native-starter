{
  "name": "Energy",
  "displayName": "Energy",
  "expo": {
    "name": "Energy",
    "slug": "react-native-starter",
    "scheme": "energy",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "net.artsy.energy",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.artsy.energy",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/short-white-logo.png",
        "backgroundColor": "#000000"
      }
    },
    "buildCacheProvider": {
      "plugin": "expo-build-disk-cache",
      "options": {
        "cacheDir": "node_modules/.expo-build-disk-cache"
      }
    },
    "plugins": [
      "react-native-keys",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./src/assets/images/short-white-logo.png",
          "imageWidth": 150
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "ndkVersion": "27.1.12297006",
            "kotlinVersion": "2.1.20",
            "reactNativeReleaseLevel": "experimental"
          },
          "ios": {
            "reactNativeReleaseLevel": "experimental",
            "buildReactNativeFromSource": false
          }
        }
      ],
      "./plugins/withAndroidBuildPerformance.js",
      [
        "expo-font",
        {
          "fonts": [
            "assets/fonts/Unica77LL-Italic.otf",
            "assets/fonts/Unica77LL-MediumItalic.otf",
            "assets/fonts/Unica77LL-Medium.otf",
            "assets/fonts/Unica77LL-Regular.otf"
          ]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "your-sentry-org",
          "project": "your-sentry-project",
          "url": "https://sentry.io/"
        }
      ]
    ]
  }
}
