{
  "name": "react-native-starter",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "android": "expo run:android --no-bundler && yarn start",
    "android:clean": "npx expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-bundler && yarn start",
    "ios:clean": "npx expo prebuild --platform ios --clean",
    "ios-device": "expo run:ios --no-bundler --device && yarn start",
    "prebuild": "npx expo prebuild --clean",
    "pod-install": "npx pod-install",
    "prepare": "husky install",
    "start": "concurrently --raw --prefix \"[{name}]\" --names \"relay,metro\" \"yarn relay:watch\" \"npx expo start\"",
    "start:reset-cache": "concurrently --raw \"yarn relay:watch\" \"npx expo start --reset-cache\"",
    "test": "jest",
    "lint": "eslint --fix --cache --cache-location '.cache/eslint/' --ext .ts,.tsx src",
    "type-check": "yarn relay && yarn tsc",
    "relay": "yarn relay-compiler",
    "relay:watch": "yarn relay --watch",
    "e2e:doctor": "agent-device doctor",
    "e2e": "agent-device test e2e/flows",
    "e2e:record": "agent-device replay --update",
    "setup:artsy": "./scripts/setup-env-for-artsy",
    "prettier-project": "yarn prettier --write 'src/**/*.{ts,tsx}'",
    "prettier-write": "prettier --write --ignore-unknown",
    "sync-schema": "curl https://raw.githubusercontent.com/artsy/metaphysics/main/_schemaV2.graphql -o data/schema.graphql; yarn prettier --write --parser graphql data/schema.graphql"
  },
  "dependencies": {
    "@artsy/icons": "3.74.0",
    "@artsy/palette-mobile": "24.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "6.1.9",
    "@react-navigation/native-stack": "6.9.17",
    "easy-peasy": "6.1.0",
    "expo": "55.0.26",
    "expo-build-properties": "55.0.14",
    "expo-dev-client": "55.0.35",
    "expo-font": "55.0.8",
    "expo-keep-awake": "55.0.8",
    "expo-splash-screen": "~55.0.21",
    "expo-system-ui": "~55.0.18",
    "formik": "^2.2.9",
    "lodash": "4.18.1",
    "luxon": "^3.2.1",
    "moti": "0.30.0",
    "qs": "^6.11.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-config": "https://github.com/artsy/react-native-config.git#v1.4.11-artsy",
    "react-native-device-info": "14.0.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-haptic-feedback": "^1.14.0",
    "react-native-linear-gradient": "2.8.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "react-relay": "^20.1.0",
    "react-relay-network-modern": "^6.2.2",
    "relay-runtime": "^20.1.0",
    "styled-components": "6.1.19",
    "styled-system": "5.1.5",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@babel/core": "7.26.0",
    "@babel/plugin-proposal-decorators": "^7.23.6",
    "@babel/plugin-transform-named-capturing-groups-regex": "^7.22.5",
    "@babel/preset-env": "7.25.3",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@babel/runtime": "7.26.10",
    "@jest/globals": "^29.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/lodash": "^4.14.191",
    "@types/luxon": "^3.2.0",
    "@types/qs": "^6.9.7",
    "@types/react": "~19.2.10",
    "@types/react-relay": "^18.2.1",
    "@types/react-test-renderer": "19.1.0",
    "@types/relay-runtime": "^19.0.2",
    "@types/relay-test-utils": "^19.0.0",
    "@types/styled-system": "^5.1.24",
    "@typescript-eslint/eslint-plugin": "5.57.0",
    "@typescript-eslint/parser": "5.57.0",
    "@typescript-eslint/utils": "5.51.0",
    "agent-device": "0.19.3",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-relay": "^20.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~55.0.0",
    "concurrently": "^7.6.0",
    "eslint": "8.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-no-relative-import-paths": "1.5.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "7.32.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "6.5.0",
    "graphql": "16.8.1",
    "husky": "^8.0.3",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "jest-extended": "1.2.1",
    "lint-staged": "13.2.3",
    "pod-install": "1.0.18",
    "prettier": "3.1.1",
    "react-test-renderer": "19.2.0",
    "relay-compiler": "^20.1.0",
    "relay-test-utils": "18.2.0",
    "typescript": "5.9.2"
  },
  "resolutions": {
    "tslib": ">=2.6.1"
  },
  "lint-staged": {
    "*.@(js|jsx|ts|tsx)": [
      "yarn lint",
      "prettier --write --ignore-unknown"
    ]
  },
  "packageManager": "yarn@4.10.0"
}
